# Sunucu
PORT=3000
NODE_ENV=development

# İlk kurulumda varsayılan admin şifresi: Admin123! (kullanıcı adı: admin)

# Oturum ve güvenlik (üretimde mutlaka değiştirin)
SESSION_SECRET=uzun-ve-rastgele-bir-secret-key-buraya

# reCAPTCHA v2 (3 başarısız denemeden sonra zorunlu)
# https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# Şifremi unuttum e-posta (opsiyonel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@geliruzmanlari.gov.tr

# Bakım modu: 1 ise admin paneli kapalı
# MAINTENANCE=0

# Admin IP beyaz listesi (virgülle ayrılmış, boş ise tüm IP'ler)
# ADMIN_IP_WHITELIST=127.0.0.1,::1
